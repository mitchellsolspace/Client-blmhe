		{# Be sure to update title in this JSON file #}
		<link rel="manifest" href="/pgs/build/img/icons/manifest.json">
		{# END Icons #}

		{# 1200px x 630px min. 1.9:1 aspect ratio, 8MB max size - use OpenGraph Debugger to validate #}
