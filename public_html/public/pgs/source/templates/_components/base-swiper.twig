{#
	This is a basic, image-only Swiper. Anything that needs more functionality should have a new compnent with a name like: base-swiper-image-and-video

  Requires:
  js/components/swiper.js
  scss/components/_swiper.scss
#}

{# Not using this because the image will load in lazily with a blur effect and the loader is redunant #}
{# {% macro spinner() %}
	<div class="swiper-lazy-preloader">
		<div class="spinner">
			<div class="rect1"></div>
			<div class="rect2"></div>
			<div class="rect3"></div>
			<div class="rect4"></div>
			<div class="rect5"></div>
		</div>
	</div>
{% endmacro %} #}

<div class="swiper {{swiperClasses}}">

	<div>
		<div class="swiper-container">
			<div class="swiper-wrapper">
				{% for image in images %}
				
					<figure class="swiper-slide embed-responsive embed-responsive-2by1">
						<a href="{{image.link}}">
						{# Note I'm am applying a value of 100vw to the sizes attribute because Swiper.js's lazy loading implementation does not offer dynamic assignment (like lazysizes.js does). I'm hard-coding it for convenience's sake. #}
						<img src="{{image.swiperImageLowQuality}}" data-src="{{image.swiperImage1x}}" data-srcset="{% for im in image.swiperImages %}{{im.img}} {{im.width}}w{% if loop.last != true %},{% endif %}{% endfor %}" class="swiper-lazy" alt="{{image.alt}}" sizes="100vw">
						{# {{_self.spinner}} #}
						{% include "_components/base-image-caption" with {
						imageCaptionTag : image.caption.tag,
						imageCaptionCaption : image.caption.caption,
						imageCaptionClasses : "swiper-caption"
					} %}
						</a>
					</figure>
				{% endfor %}

			</div>
		</div>
		<div class="swiper-pagination js-swiper-pagination-{{loop.index0}}"></div>
	</div>

</div>
